# Application
APP_ENV=local
APP_NAME="CRM Lite"
APP_PORT=8080

# PostgreSQL
DB_HOST=your-postgres-host
DB_PORT=5432
DB_NAME=your-database-name
DB_USER=your-database-user
DB_PASSWORD=your-database-password
DB_SSLMODE=require

# Redis
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# CLOUDINARY
CLOUDINARY_CLOUD_NAME=xxxxx
CLOUDINARY_API_KEY=xxxxx
CLOUDINARY_API_SECRET=xxxxx
CLOUDINARY_FOLDER=crm-lite

# JWT
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRATION=24h

# Frontend
FRONTEND_URLS=http://localhost:3000,https://your-frontend-domain.com

# Public URL for open-tracking pixels / webhook docs
PUBLIC_BASE_URL=http://localhost:8080

# Encrypts per-org communication provider secrets (AES-GCM). Defaults to JWT_SECRET if unset.
COMMUNICATION_SECRETS_KEY=

# Email provider bootstrap (when no org-scoped provider is configured)
EMAIL_PROVIDER=simulation
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_ENCRYPTION=starttls
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_REPLY_TO=
RESEND_WEBHOOK_SECRET=

# WhatsApp bootstrap
WHATSAPP_PROVIDER=simulation
WHATSAPP_API_URL=https://graph.facebook.com/v20.0
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=crm-lite-verify
WHATSAPP_APP_SECRET=

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# Feature Flags (config over hardcoding). Default true; set false to disable.
FEATURE_DYNAMIC_MODULES=true
FEATURE_AUTOMATION=true
FEATURE_IMPORT=true
FEATURE_EXPORT=true
FEATURE_GUIDED_TOUR=true
FEATURE_RBAC=true
